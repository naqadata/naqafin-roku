<?xml version="1.0" encoding="utf-8"?>
<component name="captionTask" extends="Task">
       <interface>
              <field id="captionStyles" type="assocarray" alwaysNotify="true" />
              <field id="url" type="string" />
              <field id="currentCaption" type="roArray" />
              <field id="playerState" type="string" />
              <field id="currentPos" type="int" />
              <field id="pollSeconds" type="integer" value="2" />
              <function name="refreshCaptionStyle" />
       </interface>
       <children>
              <timer id="captionTimer" repeat="true" duration="0.1" />
              <timer id="captionFetchTimer" repeat="true" duration="2" />
       </children>
</component>
