import "pkg:/source/enums/ColorPalette.bs"
import "pkg:/source/enums/KeyCode.bs"
import "pkg:/source/enums/TaskControl.bs"
import "pkg:/source/utils/config.bs"
import "pkg:/source/utils/misc.bs"
import "pkg:/source/utils/serverFeatures.bs"

const SUBTITLE_TIMING_MIN_MS = -5000
const SUBTITLE_TIMING_MAX_MS = 5000
const SUBTITLE_TIMING_STEP_MS = 100
const SUBTITLE_BACKGROUND_MIN_PERCENT = 0
const SUBTITLE_BACKGROUND_MAX_PERCENT = 100
const SUBTITLE_BACKGROUND_STEP_PERCENT = 5

sub init()
    m.panel = m.top.findNode("panel")
    m.panelBackground = m.top.findNode("panelBackground")
    m.focusRow = m.top.findNode("focusRow")
    m.title = m.top.findNode("title")
    m.generatedLanguageRow = m.top.findNode("generatedLanguageRow")
    m.openAiPolishRow = m.top.findNode("openAiPolishRow")
    m.clearCacheRow = m.top.findNode("clearCacheRow")
    m.rows = [
        m.top.findNode("styleRow"),
        m.top.findNode("timingRow"),
        m.top.findNode("backgroundRow")
    ]

    if serverSupportsAutoGeneratedCaptions()
        m.rows.push(m.generatedLanguageRow)
        m.generatedLanguageRow.visible = true
    else
        m.generatedLanguageRow.visible = false
    end if

    if serverSupportsAutoGeneratedCaptionPolish()
        m.rows.push(m.openAiPolishRow)
        m.openAiPolishRow.visible = true
    else
        m.openAiPolishRow.visible = false
    end if

    if serverSupportsAutoGeneratedCaptions()
        m.rows.push(m.clearCacheRow)
        m.clearCacheRow.visible = true
    else
        m.clearCacheRow.visible = false
    end if
    m.focusedIndex = 0
    m.backgroundColor = chainLookupReturn(m.global.session, "user.settings.colorDialogBackground", ColorPalette.ELEMENTBACKGROUND)
    m.borderColor = chainLookupReturn(m.global.session, "user.settings.colorDialogBorderLine", ColorPalette.LIGHTBLUE)
    m.textColor = chainLookupReturn(m.global.session, "user.settings.colorDialogText", ColorPalette.WHITE)
    m.focusColor = chainLookupReturn(m.global.session, "user.settings.colorDialogSelectedText", ColorPalette.WHITE)
    m.focusBackground = chainLookupReturn(m.global.session, "user.settings.colorCursor", ColorPalette.HIGHLIGHT)

    m.panelBackground.blendColor = m.backgroundColor
    m.focusRow.color = m.focusBackground
    m.focusRow.opacity = 0.9
    m.title.color = m.textColor
    m.title.font.size = 34

    for each row in m.rows
        row.font.size = 30
    end for

    m.styles = [
        { id: "disabled", title: tr("Disabled") },
        { id: "enabled100", title: tr("Enabled at 100%") },
        { id: "enabled90", title: tr("Enabled at 90%") },
        { id: "enabled80", title: tr("Enabled at 80%") },
        { id: "enabled70", title: tr("Enabled at 70%") },
        { id: "enabled60", title: tr("Enabled at 60%") },
        { id: "enabled50", title: tr("Enabled at 50%") }
    ]

    m.generatedLanguages = [
        { id: "auto", title: tr("Auto") },
        { id: "en", title: tr("English") }
    ]

    m.openAiPolishOptions = [
        { id: "enabled", title: tr("Enabled") },
        { id: "disabled", title: tr("Disabled") }
    ]

    loadValues()
    updateRows()
end sub

sub loadValues()
    m.styleIndex = getStyleIndex(getSubtitleStyleSettingId())
    m.timingOffsetMs = getActiveSubtitleTimingOffset()
    m.backgroundOpacity = clampInt(getIntSetting("playback.subs.backgroundOpacity", 0), SUBTITLE_BACKGROUND_MIN_PERCENT, SUBTITLE_BACKGROUND_MAX_PERCENT)
    m.generatedLanguageIndex = getGeneratedLanguageIndex(getAutoGeneratedCaptionLanguageSetting())
    m.openAiPolishIndex = getOpenAiPolishIndex(getAutoGeneratedCaptionPolishSetting())
end sub

sub show()
    loadValues()
    updateRows()
    m.top.visible = true
    m.top.setFocus(true)
end sub

sub hide()
    m.top.setFocus(false)
    m.top.visible = false
    m.top.wasClosed = true
    activeScene = m.global.sceneManager.callFunc("getActiveScene")
    if isValid(activeScene)
        activeScene.setFocus(true)
    end if
end sub

sub updateRows()
    m.rows[0].text = tr("Enhanced Styling") + ": " + m.styles[m.styleIndex].title
    m.rows[1].text = tr("Timing") + ": " + formatTiming(m.timingOffsetMs) + "  " + getSliderText(m.timingOffsetMs, SUBTITLE_TIMING_MIN_MS, SUBTITLE_TIMING_MAX_MS)
    if isEnhancedStylingDisabled()
        m.rows[2].text = tr("Background") + ": " + tr("Disabled")
    else
        m.rows[2].text = tr("Background") + ": " + m.backgroundOpacity.toStr() + "%  " + getSliderText(m.backgroundOpacity, SUBTITLE_BACKGROUND_MIN_PERCENT, SUBTITLE_BACKGROUND_MAX_PERCENT)
    end if
    if serverSupportsAutoGeneratedCaptions()
        m.generatedLanguageRow.text = tr("Generated Language") + ": " + m.generatedLanguages[m.generatedLanguageIndex].title
    end if
    if serverSupportsAutoGeneratedCaptionPolish()
        m.openAiPolishRow.text = tr("Enable OpenAI Polish") + ": " + m.openAiPolishOptions[m.openAiPolishIndex].title
    end if
    if serverSupportsAutoGeneratedCaptions()
        m.clearCacheRow.text = tr("Clear Auto-Generated Subtitle Cache")
    end if
    m.focusRow.translation = [36, 86 + (m.focusedIndex * 62)]

    for i = 0 to m.rows.count() - 1
        m.rows[i].color = i = m.focusedIndex ? m.focusColor : m.textColor
    end for

    if isEnhancedStylingDisabled()
        m.rows[2].color = m.focusedIndex = 2 ? ColorPalette.LIGHTGREY : ColorPalette.MIDGREY
    end if
end sub

function onKeyEvent(key as string, press as boolean) as boolean
    if not press then return false

    if key = KeyCode.UP
        m.focusedIndex--
        if m.focusedIndex < 0 then m.focusedIndex = m.rows.count() - 1
        updateRows()
        return true
    end if

    if key = KeyCode.DOWN
        m.focusedIndex++
        if m.focusedIndex >= m.rows.count() then m.focusedIndex = 0
        updateRows()
        return true
    end if

    if key = KeyCode.LEFT
        adjustFocusedRow(-1)
        return true
    end if

    if key = KeyCode.RIGHT
        adjustFocusedRow(1)
        return true
    end if

    if key = KeyCode.OK
        if focusedRowIs(m.clearCacheRow)
            clearAutoGeneratedSubtitleCache()
            return true
        end if

        hide()
        return true
    end if

    if key = KeyCode.BACK
        hide()
        return true
    end if

    return false
end function

sub adjustFocusedRow(direction as integer)
    if m.focusedIndex = 0
        m.styleIndex += direction
        if m.styleIndex < 0
            m.styleIndex = m.styles.count() - 1
        else if m.styleIndex >= m.styles.count()
            m.styleIndex = 0
        end if

        set_user_setting("playback.subs.enhancedStyle", m.styles[m.styleIndex].id)
    else if m.focusedIndex = 1
        m.timingOffsetMs = clampInt(m.timingOffsetMs + (direction * SUBTITLE_TIMING_STEP_MS), SUBTITLE_TIMING_MIN_MS, SUBTITLE_TIMING_MAX_MS)
        setActiveSubtitleTimingOffset(m.timingOffsetMs)
    else if m.focusedIndex = 2
        if isEnhancedStylingDisabled() then return
        m.backgroundOpacity = clampInt(m.backgroundOpacity + (direction * SUBTITLE_BACKGROUND_STEP_PERCENT), SUBTITLE_BACKGROUND_MIN_PERCENT, SUBTITLE_BACKGROUND_MAX_PERCENT)
        set_user_setting("playback.subs.backgroundOpacity", m.backgroundOpacity.toStr())
    else if focusedRowIs(m.generatedLanguageRow)
        m.generatedLanguageIndex += direction
        if m.generatedLanguageIndex < 0
            m.generatedLanguageIndex = m.generatedLanguages.count() - 1
        else if m.generatedLanguageIndex >= m.generatedLanguages.count()
            m.generatedLanguageIndex = 0
        end if

        set_user_setting("playback.subs.autoGeneratedLanguage", m.generatedLanguages[m.generatedLanguageIndex].id)
    else if focusedRowIs(m.openAiPolishRow)
        m.openAiPolishIndex += direction
        if m.openAiPolishIndex < 0
            m.openAiPolishIndex = m.openAiPolishOptions.count() - 1
        else if m.openAiPolishIndex >= m.openAiPolishOptions.count()
            m.openAiPolishIndex = 0
        end if

        set_user_setting("playback.subs.autoGeneratedOpenAiPolish", m.openAiPolishOptions[m.openAiPolishIndex].id)
    end if

    updateRows()
    refreshActiveCaptions()
end sub

sub refreshActiveCaptions()
    activeScene = m.global.sceneManager.callFunc("getActiveScene")
    if isValid(activeScene)
        activeScene.callFunc("refreshCaptionStyle")
    end if
end sub

sub clearAutoGeneratedSubtitleCache()
    if not isValidAndNotEmpty(m.top.itemId) then return
    if isValid(m.clearCacheTask) then return

    m.clearCacheTask = CreateObject("roSGNode", "AutoGenerateCaptionSessionTask")
    m.clearCacheTask.action = "clear"
    m.clearCacheTask.itemId = m.top.itemId
    m.clearCacheTask.mediaSourceId = m.top.mediaSourceId
    m.clearCacheTask.audioStreamIndex = m.top.audioStreamIndex
    m.clearCacheTask.language = getAutoGeneratedCaptionLanguageSetting()
    m.clearCacheTask.observeField("response", "onClearAutoGeneratedSubtitleCacheResponse")
    m.clearCacheTask.observeField("error", "onClearAutoGeneratedSubtitleCacheError")
    m.clearCacheTask.control = TaskControl.RUN
end sub

sub onClearAutoGeneratedSubtitleCacheResponse()
    cleanupClearCacheTask()
    showAutoGeneratedSubtitleCacheDialog(tr("Auto-generated subtitle cache cleared."))
end sub

sub onClearAutoGeneratedSubtitleCacheError()
    cleanupClearCacheTask()
    showAutoGeneratedSubtitleCacheDialog(tr("Unable to clear auto-generated subtitle cache."))
end sub

sub cleanupClearCacheTask()
    if not isValid(m.clearCacheTask) then return

    m.clearCacheTask.unobserveField("response")
    m.clearCacheTask.unobserveField("error")
    m.clearCacheTask = invalid
end sub

sub showAutoGeneratedSubtitleCacheDialog(message as string)
    dialog = createObject("roSGNode", "Dialog")
    dialog.title = tr("Auto-Generated Subtitles")
    dialog.buttons = [tr("OK")]
    dialog.message = message
    dialog.observeField("buttonSelected", "onAutoGeneratedSubtitleCacheDialogButtonSelected")
    m.autoGeneratedSubtitleCacheDialog = dialog
    m.top.getScene().dialog = dialog
end sub

sub onAutoGeneratedSubtitleCacheDialogButtonSelected()
    if not isValid(m.autoGeneratedSubtitleCacheDialog) then return

    m.autoGeneratedSubtitleCacheDialog.unobserveField("buttonSelected")
    m.autoGeneratedSubtitleCacheDialog.close = true
    m.autoGeneratedSubtitleCacheDialog = invalid
end sub

function getActiveSubtitleTimingOffset() as integer
    activeScene = m.global.sceneManager.callFunc("getActiveScene")
    if isValid(activeScene) and isValid(activeScene.subtitleTimingOffsetMs)
        return clampInt(activeScene.subtitleTimingOffsetMs, SUBTITLE_TIMING_MIN_MS, SUBTITLE_TIMING_MAX_MS)
    end if

    return 0
end function

sub setActiveSubtitleTimingOffset(offsetMs as integer)
    activeScene = m.global.sceneManager.callFunc("getActiveScene")
    if isValid(activeScene) and isValid(activeScene.subtitleTimingOffsetMs)
        activeScene.subtitleTimingOffsetMs = offsetMs
    end if
end sub

function getSubtitleStyleSettingId() as string
    settingValue = chainLookupReturn(m.global, "session.user.settings.`playback.subs.enhancedStyle`", "enabled100")

    if isStringEqual(type(settingValue), "roBoolean") or isStringEqual(type(settingValue), "Boolean")
        return settingValue ? "enabled100" : "disabled"
    end if

    if isStringEqual(settingValue, "disabled") then return "disabled"
    if isStringEqual(settingValue, "enabled50") then return "enabled50"
    if isStringEqual(settingValue, "enabled60") then return "enabled60"
    if isStringEqual(settingValue, "enabled70") then return "enabled70"
    if isStringEqual(settingValue, "enabled75") then return "enabled70"
    if isStringEqual(settingValue, "enabled80") then return "enabled80"
    if isStringEqual(settingValue, "enabled90") then return "enabled90"
    return "enabled100"
end function

function isEnhancedStylingDisabled() as boolean
    return isStringEqual(m.styles[m.styleIndex].id, "disabled")
end function

function getStyleIndex(styleId as string) as integer
    for i = 0 to m.styles.count() - 1
        if isStringEqual(m.styles[i].id, styleId) then return i
    end for

    return 1
end function

function getAutoGeneratedCaptionLanguageSetting() as string
    settingValue = chainLookupReturn(m.global, "session.user.settings.`playback.subs.autoGeneratedLanguage`", "auto")
    return normalizeAutoGeneratedCaptionLanguage(settingValue)
end function

function getGeneratedLanguageIndex(languageId as string) as integer
    normalizedLanguageId = normalizeAutoGeneratedCaptionLanguage(languageId)

    for i = 0 to m.generatedLanguages.count() - 1
        if isStringEqual(m.generatedLanguages[i].id, normalizedLanguageId) then return i
    end for

    return 0
end function

function getAutoGeneratedCaptionPolishSetting() as string
    if not serverSupportsAutoGeneratedCaptionPolish() then return "disabled"

    settingValue = chainLookupReturn(m.global, "session.user.settings.`playback.subs.autoGeneratedOpenAiPolish`", "enabled")
    if not isValid(settingValue) then return "enabled"

    normalized = LCase(settingValue.toStr())
    if normalized = "disabled" or normalized = "false" or normalized = "off" then return "disabled"
    return "enabled"
end function

function getOpenAiPolishIndex(settingId as string) as integer
    for i = 0 to m.openAiPolishOptions.count() - 1
        if isStringEqual(m.openAiPolishOptions[i].id, settingId) then return i
    end for

    return 0
end function

function focusedRowIs(row as object) as boolean
    if m.focusedIndex < 0 or m.focusedIndex >= m.rows.count() then return false
    return isValid(row) and isStringEqual(m.rows[m.focusedIndex].id, row.id)
end function

function normalizeAutoGeneratedCaptionLanguage(value as dynamic) as string
    if not isValid(value) then return "auto"

    language = LCase(value.toStr())
    if language = "eng" or language = "english" then return "en"
    if language = "en" then return "en"
    return "auto"
end function

function getIntSetting(settingName as string, defaultValue as integer) as integer
    settingValue = m.global.session.user.settings.LookupCI(settingName)
    if not isValid(settingValue) then return defaultValue

    return int(val(settingValue.toStr()))
end function

function clampInt(value as integer, minValue as integer, maxValue as integer) as integer
    if value < minValue then return minValue
    if value > maxValue then return maxValue
    return value
end function

function formatTiming(value as integer) as string
    if value > 0 then return "+" + value.toStr() + "ms"
    return value.toStr() + "ms"
end function

function getSliderText(value as integer, minValue as integer, maxValue as integer) as string
    slotCount = 20
    range = maxValue - minValue
    filledSlots = int(((value - minValue) * slotCount) / range)
    if filledSlots < 0 then filledSlots = 0
    if filledSlots > slotCount then filledSlots = slotCount

    sliderText = "["
    for i = 0 to slotCount
        if i = filledSlots
            sliderText += "|"
        else
            sliderText += "-"
        end if
    end for
    sliderText += "]"

    return sliderText
end function
