{
  "files": [
    "manifest",
    "source/**/*.*",
    "components/**/*.*",
    "images/**/*.*",
    "locale/de_DE/**/*.*",
    "locale/en_GB/**/*.*",
    "locale/en_US/**/*.*",
    "locale/es_ES/**/*.*",
    "locale/fr_CA/**/*.*",
    "locale/it_IT/**/*.*",
    "locale/pl/**/*.*",
    "locale/pt_BR/**/*.*",
    "settings/*.*"
  ],
  "plugins": ["@rokucommunity/bslint"],
  "diagnosticFilters": ["node_modules/**/*", "**/roku_modules/**/*"],
  "sourceMap": true,
  "autoImportComponentScript": true,
  "stagingDir": "build/staging",
  "retainStagingDir": true
}
